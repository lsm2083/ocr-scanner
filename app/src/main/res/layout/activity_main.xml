<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".MainActivity">

    <!-- Processed camera frames are drawn here -->
    <ImageView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/preview_desc"
        android:scaleType="fitCenter" />

    <!-- Live-translation direction toggle (visible only in 실시간 번역 mode) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_margin="12dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:visibility="gone"
        tools:text="번역: 자동" />

    <!-- Front/back camera toggle -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_flip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:text="@string/flip" />

    <!-- FPS / native processing time -->
    <TextView
        android:id="@+id/fps_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:background="#80000000"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:textColor="#00FF00"
        android:textStyle="bold"
        tools:text="FPS: 30  |  native: 4.2 ms" />

    <!-- Control panel -->
    <LinearLayout
        android:id="@+id/control_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#C0000000"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_label"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinner_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:entries="@array/modes" />
            </LinearLayout>

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/res_label"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinner_res"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:entries="@array/resolutions" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/label_low"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@android:color/white"
            tools:text="하한 임계값: 50" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_low"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="50"
            android:valueFrom="0"
            android:valueTo="255"
            android:stepSize="1" />

        <TextView
            android:id="@+id/label_high"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            tools:text="상한 임계값: 150" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_high"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="150"
            android:valueFrom="0"
            android:valueTo="255"
            android:stepSize="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_capture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:text="@string/capture" />

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:text="@string/share" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
